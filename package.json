{
  "name": "react-chartist",
  "version": "1.0.0-rc.1",
  "description": "A small, typed React component for Chartist.js",
  "keywords": [
    "react",
    "react-component",
    "chartist",
    "charts",
    "svg"
  ],
  "license": "MIT",
  "author": {
    "name": "Fraser Xu",
    "email": "xvfeng123@gmail.com",
    "url": "https://fraserxu.me"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fraserxu/react-chartist.git"
  },
  "bugs": {
    "url": "https://github.com/fraserxu/react-chartist/issues"
  },
  "homepage": "https://github.com/fraserxu/react-chartist#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "packageManager": "npm@11.18.0",
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run typecheck:package",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "npm run check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:package": "tsc --ignoreConfig --noEmit --strict --skipLibCheck --target ES2022 --module NodeNext --moduleResolution NodeNext test/package-consumer.mts"
  },
  "peerDependencies": {
    "chartist": "^1.5.0",
    "react": "^18.2.0 || ^19.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "chartist": "^1.5.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
